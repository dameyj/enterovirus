{
  "$schema": "https://raw.githubusercontent.com/nextstrain/nextclade/refs/heads/release/packages/nextclade-schemas/input-pathogen-json.schema.json",
  "schemaVersion": "3.0.0",
  "files": {
    "reference": "reference.fasta",
    "pathogenJson": "pathogen.json",
    "genomeAnnotation": "genome_annotation.gff3",
    "examples": "sequences.fasta"
  },
  "attributes": {
    "name": "Human Rhinovirus B",
    "reference name": "Human Rhinovirus B14",
    "reference accession": "NC_001490"
  },
  "alignmentParams": {
    "penaltyGapExtend":3,
    "penaltyGapOpen": 16,
    "penaltyGapOpenInFrame": 20,
    "penaltyGapOpenOutOfFrame": 25,
    "kmerLength": 6,
    "kmerDistance": 15,
    "minMatchLength": 25,
    "allowedMismatches": 10,
    "minLength": 100,
    "gapAlignmentSide": "right",
    "retryReverseComplement": true,
    "minSeedCover": 0.40
  },
  "defaultCds": "VP1",
  "compatibility": {
        "cli": "3.0.0",
        "web": "3.0.0"
    },
  "qc": {
    "frameShifts": {
      "enabled": true,
      "scoreWeight": 100
    },
    "missingData": {
      "enabled": true,
      "missingDataThreshold": 1000,
      "scoreBias": 100
    },
    "mixedSites": {
      "enabled": true,
      "mixedSitesThreshold": 10
    },
    "privateMutations": {
      "enabled": true,
      "cutoff": 120,
      "typical": 40,
      "weightLabeledSubstitutions": 1.5,
      "weightReversionSubstitutions": 2,
      "weightUnlabeledSubstitutions": 1
    },
    "divergence": {
      "enabled": true,
      "maxDivergence": 0.15,
      "scoreWeight": 50
    },
    "stopCodons": {
      "enabled": true,
      "scoreWeight": 60
    }
    },
    "cdsOrderPreference": [
      "VP4","VP2","VP3","VP1",
      "2A","2B","2C",
      "3A","3B","3C","3D"
    ]
  }